<configuration scan="true" scanPeriod="30 seconds">

  <!-- ========================= -->
  <!-- Console Output - Pretty & Color -->
  <!-- ========================= -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
      <pattern>%highlight(%d{yyyy-MM-dd HH:mm:ss.SSS}) [%thread] %-5level %cyan(%logger{36}) - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- ========================= -->
  <!-- General Log File -->
  <!-- ========================= -->
  <appender name="log" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>./logs/gatling.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>./logs/gatling.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>10</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- ========================= -->
  <!-- Error-Only Log File -->
  <!-- ========================= -->
  <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>./logs/gatling-error.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>./logs/gatling-error.%d{yyyy-MM-dd}.log</fileNamePattern>
      <maxHistory>10</maxHistory>
    </rollingPolicy>
    <filter class="ch.qos.logback.classic.filter.LevelFilter">
      <level>ERROR</level>
      <onMatch>ACCEPT</onMatch>
      <onMismatch>DENY</onMismatch>
    </filter>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- ========================= -->
  <!-- Gatling and HTTP Logs -->
  <!-- ========================= -->
  <logger name="io.gatling.http.engine.response" level="DEBUG" />
  <logger name="io.gatling.http" level="DEBUG" />
  <logger name="io.gatling.core" level="INFO" />
  <logger name="io.gatling" level="INFO" />

  <!-- ========================= -->
  <!-- Root Logger - All Levels -->
  <!-- ========================= -->
  <root level="TRACE">
    <appender-ref ref="CONSOLE" />
    <appender-ref ref="log" />          <!-- ✅ corrected -->
    <appender-ref ref="ERROR_FILE" />
  </root>

</configuration>
